<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Support</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <nav>
        <a href="/">
            <img src="ae-logo-nav.png" alt="AETicketHub Logo" class="nav-logo">
        </a>
        <ul class="nav-links"></ul>
    </nav>

    <div class="container">
        <div class="panel contact-panel">
            <h2 class="page-title">Contact Support</h2>
            <p class="muted">Experiencing issues with your booking? Drop us a message and our IT team will investigate.</p>
            
            <form id="contactForm">
                <label>Full Name</label>
                <input type="text" id="cName" required>
                
                <label>Email Address</label>
                <input type="email" id="cEmail" required>
                
                <label>Message Details</label>
                <textarea id="cMsg" rows="5" required></textarea>
                
                <button type="submit">Submit Ticket</button>
                <p id="contactSuccess" class="success hidden">Your support ticket has been logged successfully.</p>
            </form>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
