<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Support</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <nav>
        <a href="index.html">
            <img src="AE logo.png.png" alt="AETicketHub Logo" class="nav-logo">
        </a>
        <ul class="nav-links"></ul>
    </nav>

    <div class="container">
        <div style="background:white; padding:40px 30px; border-radius:8px; max-width: 600px; margin: 0 auto; box-shadow:0 4px 6px rgba(0,0,0,0.05);">
            <h2 style="color: var(--main-blue); margin-top: 0;">Contact Support</h2>
            <p style="color: #666; margin-bottom: 25px;">Experiencing issues with your booking? Drop us a message and our IT team will investigate.</p>
            
            <form id="contactForm">
                <label>Full Name</label>
                <input type="text" id="cName" required>
                
                <label>Email Address</label>
                <input type="email" id="cEmail" required>
                
                <label>Message Details</label>
                <textarea id="cMsg" rows="5" required></textarea>
                
                <button type="submit">Submit Ticket</button>
                <p id="contactSuccess" class="success hidden" style="margin-top:15px; font-weight: bold;">Your support ticket has been logged successfully.</p>
            </form>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>