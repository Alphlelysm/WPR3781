<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Tickets</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <nav>
        <a href="/">
            <img src="ae-logo-nav.png" alt="AETicketHub Logo" class="nav-logo">
        </a>
        <ul class="nav-links"></ul>
    </nav>

    <div class="container">
        <div id="eventInfo" class="panel">
            <button class="secondary inline-button" onclick="window.location.href='/'">&larr; Back to Events</button>
            
            <h1 id="evTitle" class="page-title">Loading...</h1>
            <p id="evDate"></p>
            <p id="evVenue"></p>
            <p id="evTickets" class="ticket-status"></p>
            
            <hr class="divider">

            <div id="bookingSection" class="booking-panel">
                <h3>Secure Your Tickets</h3>
                <label>Number of Tickets:</label>
                <input type="number" id="ticketQty" value="1" min="1">
                <button id="bookBtn" class="inline-button">Confirm Booking</button>
                <span id="bookMsg" class="error"></span>
            </div>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
