<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - AETicketHub</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <nav>
        <a href="/">
            <img src="AE logo.png.png" alt="AETicketHub Logo" class="nav-logo">
        </a>
        <ul class="nav-links"></ul>
    </nav>

    <div class="container">
        <div class="dashboard-header">
            <h2 id="welcomeText" class="page-title">Dashboard</h2>
        </div>

        <!-- standard user dashboard -->
        <div id="userSection" class="hidden">
            <h3>My Ticket Bookings</h3>
            <div id="myTicketsList"></div>
        </div>

        <!-- admin dashboard -->
        <div id="adminSection" class="hidden">
            
            <div class="stats-grid">
                <div class="stat-card feature">
                    <h4>Total Active Events</h4>
                    <h2 id="totalEventsStat">0</h2>
                </div>
                <div class="stat-card alert">
                    <h4>Total Tickets Sold</h4>
                    <h2 id="totalBookingsStat">0</h2>
                </div>
                <div class="stat-card">
                    <h4>Total Revenue</h4>
                    <h2 id="totalRevenueStat">R0</h2>
                </div>
            </div>

            <div class="admin-grid">
                <div class="card">
                    <h3>Popular Events</h3>
                    <div id="popularEventsList"></div>
                </div>
                <div class="card">
                    <h3>Capacity Usage</h3>
                    <div id="capacityUsageList"></div>
                </div>
            </div>

            <div class="panel admin-form-panel">
                <h3>Add New Event</h3>
                <form id="createEventForm">
                    <input type="text" id="newEvName" placeholder="Event Name" required>
                    <input type="date" id="newEvDate" required>
                    <input type="text" id="newEvVenue" placeholder="Venue Location" required>
                    <input type="number" id="newEvCap" placeholder="Maximum Capacity" required>
                    <select id="newEvCat">
                        <option value="corporate">Corporate Conference</option>
                        <option value="workshop">Workshop</option>
                        <option value="festival">Music Festival</option>
                        <option value="private">Private Event</option>
                    </select>
                    <button type="submit">Create Event in System</button>
                </form>
            </div>

            <h3>Event Management</h3>
            <div id="adminEventsList"></div>

            <h3>Enquiry Management</h3>
            <div id="adminEnquiriesList"></div>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
