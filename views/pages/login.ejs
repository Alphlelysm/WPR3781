<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - AETicketHub</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <nav>
        <a href="/">
            <img src="AE logo.png.png" alt="AETicketHub Logo" class="nav-logo">
        </a>
        <ul class="nav-links"></ul>
    </nav>

    <div class="container auth-wrapper">
        <div>
            <h2>System Login</h2>
            <p class="muted">Log in to book tickets or access the admin panel.</p>
            <form id="loginForm">
                <label>Email</label>
                <input type="email" id="loginEmail" required>
                <label>Password</label>
                <input type="password" id="loginPass" required>
                <span id="loginMsg" class="error"></span>
                <button type="submit">Log In</button>
                <p class="auth-link">
                 Don’t have an account?
                 <a href="/register">
                     Please register
                  </a>
                </p>
            </form>
            <div class="dash-box">
                <strong>Lecturer Note:</strong> Log in with the admin account email address and password to access the Admin Dashboard.
            </div>
        </div>

    </div>

    <script src="/script.js"></script>
</body>
</html>
