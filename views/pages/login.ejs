<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - AETicketHub</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <nav>
        <a href="index.html">
            <img src="AE logo.png.png" alt="AETicketHub Logo" class="nav-logo">
        </a>
        <ul class="nav-links"></ul>
    </nav>

    <div class="container auth-wrapper">
        <div style="flex:1; background:white; padding:30px; border-radius:8px; box-shadow:0 4px 6px rgba(0,0,0,0.1);">
            <h2>System Login</h2>
            <p style="color: #666; font-size: 14px;">Log in to book tickets or access the admin panel.</p>
            <form id="loginForm">
                <label>Email</label>
                <input type="email" id="loginEmail" required>
                <label>Password</label>
                <input type="password" id="loginPass" required>
                <span id="loginMsg" class="error"></span>
                <button type="submit">Log In</button>
                <p style="font-size: 13px; margin-top: 10px;">
                 Don’t have an account?
                 <a href="/register" style="color: blue; text-decoration: none;">
                     Please register
                  </a>
                </p>
            </form>
            <div style="margin-top: 20px; padding: 10px; background: #eef2fa; border-radius: 4px; font-size: 13px;">
                <strong>Lecturer Note:</strong> Log in with the admin account email address and password to access the Admin Dashboard.
            </div>
        </div>

    </div>

    <script src="/script.js"></script>
</body>
</html>
